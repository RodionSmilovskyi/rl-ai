{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug local train PPO",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/train_ppo.py",
            "console": "integratedTerminal",
            "args": [
                "--prefix", "ppo-pendulum-local",
                "--total-timesteps", "400000",
                "--seed", "0",
                "--lr", "0.0003",
                "--batch-size", "64",
                "--env-id", "Pendulum-v1"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "Debug aws train PPO",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/aws-train-ppo.py",
            "console": "integratedTerminal",
            "args": [
                "--prefix", "ppo-pendulum-aws",
                "--total-timesteps", "400000",
                "--seed", "0",
                "--lr", "0.0003",
                "--batch-size", "64",
                "--env-id", "Pendulum-v1"
            ]
        },
        {
            "name": "Debug local train SAC",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/train_sac.py",
            "console": "integratedTerminal",
            "args": [
                "--prefix", "sac-pendulum-local",
                "--total-timesteps", "40000",
                "--seed", "0",
                "--lr", "0.001",
                "--batch-size", "256",
                "--env-id", "Pendulum-v1"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "Debug aws train SAC",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/aws-train-sac.py",
            "console": "integratedTerminal",
            "args": [
                "--prefix", "sac-pendulum-aws",
                "--total-timesteps", "100000",
                "--seed", "0",
                "--lr", "0.0003",
                "--batch-size", "256",
                "--env-id", "Pendulum-v1"
            ]
        },
        {
            "name": "Test Drone Render",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/test_drone_render.py",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        }
    ]
}