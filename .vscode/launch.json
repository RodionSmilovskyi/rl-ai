{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug local train Altitude PPO",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/train_altitude_curriculum_ppo.py",
            "console": "integratedTerminal",
            "args": [
                "--prefix",
                "ppo-altitude-local",
                "--total-timesteps",
                "200000",
                "--seed",
                "0",
                "--lr",
                "0.0003",
                "--batch-size",
                "64",
                "--max-phase",
                "4"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "Debug aws train Altitude PPO",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/aws-train-altitude-ppo.py",
            "console": "integratedTerminal",
            "args": [
                "--job-name",
                "ppo"
            ]
        },
        {
            "name": "Debug local train Altitude SAC",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/train_altitude_curriculum.py",
            "console": "integratedTerminal",
            "args": [
                "--prefix",
                "sac-altitude-local",
                "--total-timesteps",
                "200000",
                "--seed",
                "0",
                "--lr",
                "0.0003",
                "--batch-size",
                "256",
                "--max-phase",
                "4"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "Debug aws train Altitude SAC",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/aws-train-altitude.py",
            "console": "integratedTerminal",
            "args": [
                "--job-name",
                "sac",
                "--max-phase",
                "1"
            ]
        },
          {
            "name": "Test: HRL Wrapper Params",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tests/test_hrl_wrapper_params.py",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "Test: Drone Render",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tests/test_drone_render.py",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "Test: Inference",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tests/test_inference.py",
            "console": "integratedTerminal",
            "args": [
                "--model-path",
                "${workspaceFolder}/trained_models/model_phase_4_final_sac.tflite",
                "--goal-alt",
                "0.65",
                "--render",
                "--max-steps",
                "50"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "Conversion",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tests/test_conversion.py",
            "console": "integratedTerminal",
            "args": [
                "--model-path",
                "${workspaceFolder}/trained_models/model_phase_4_final_sac.pt",
                "--output-path",
                "${workspaceFolder}/trained_models/model_phase_4_final_sac.tflite"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        }
    ]
}
